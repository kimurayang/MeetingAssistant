# [必要] HuggingFace Token (用於 Pyannote 3.1 發言人辨識)
# 申請與接受協議路徑: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# [必要] 本地 LLM 模型路徑 (GGUF 格式)
# 建議下載: Llama-3-Taiwan-8B-Instruct.Q4_K_M.gguf
LLM_MODEL_PATH=D:\Python\VoxNote\models\Llama-3-Taiwan-8B-Instruct.Q4_K_M.gguf

# STT 模型大小 (tiny, base, small, medium, large-v3-turbo)
STT_MODEL_SIZE=large-v3-turbo

# Sidecar 埠號
PORT=8000

# 資料庫路徑 (Prisma)
DATABASE_URL="file:./dev.db"
